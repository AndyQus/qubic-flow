# Database
DATABASE_URL=sqlite:////app/data/qubicflow.db

# API
QUBIC_RPC_URL=https://rpc.qubic.org
QX_API_URL=https://qxinfo.qubic.org/api
COINGECKO_API_URL=https://api.coingecko.com/api/v3
COINGECKO_API_KEY=

# CORS
CORS_ORIGINS=http://localhost:8080,http://localhost:5173

# App
# production (default) or development — dev pre-enables the balance history
# capture series for testing; in production users enable them in the settings
APP_ENV=production
LOG_LEVEL=INFO
TZ=UTC
